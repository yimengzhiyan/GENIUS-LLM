*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- 3. Virtual Environments & IDE Settings (VS Code Specific) ---
.vscode/
.history/
*.code-workspace
venv/
.venv/
env/
ENV/
*.exe
.pyc
GENIUS_LLM/Scripts/*.exe
